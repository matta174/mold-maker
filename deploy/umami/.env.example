# Copy to .env and fill in. Never commit the real .env.
#
# Generate secrets with: openssl rand -hex 32
# (run that command twice — once per secret — so they're independent).

# --- Postgres ---
# POSTGRES_USER can be anything; "umami" is conventional. POSTGRES_DB likewise.
# POSTGRES_PASSWORD must be a random string — 32 hex chars is plenty.
POSTGRES_USER=umami
POSTGRES_DB=umami
POSTGRES_PASSWORD=REPLACE_ME_WITH_RANDOM_32_CHAR_HEX

# --- Umami ---
# APP_SECRET is used to sign JWTs and encrypt session state. If you lose it,
# all existing admin sessions are invalidated (which is fine). If someone
# else gets it, they can forge admin sessions — treat it like a password.
APP_SECRET=REPLACE_ME_WITH_RANDOM_32_CHAR_HEX
