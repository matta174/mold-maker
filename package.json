{
  "name": "mold-maker",
  "version": "0.1.0-beta.1",
  "description": "Source-available two-part mold generator for 3D printing. Load an STL/OBJ, pick a parting plane, export print-ready mold halves with auto-generated sprues, vents, and registration pins.",
  "main": ".vite/build/electron.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "mold",
    "3d-printing",
    "silicone",
    "stl",
    "electron",
    "three.js",
    "manifold",
    "csg"
  ],
  "author": "Matthew Compton <matthewc174@gmail.com>",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/matta174/mold-maker.git"
  },
  "bugs": {
    "url": "https://github.com/matta174/mold-maker/issues"
  },
  "homepage": "https://matta174.github.io/mold-maker/",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/shared-types": "^7.11.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.0",
    "electron": "^41.2.0",
    "happy-dom": "^15.11.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "manifold-3d": "^3.4.1",
    "opencascade.js": "^1.1.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "three": "^0.183.2"
  }
}
